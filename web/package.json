{
  "name": "wifiyka-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:swagger-ui": "node ./scripts/sync-swagger-ui.mjs",
    "dev": "npm run sync:swagger-ui && vite",
    "build": "npm run sync:swagger-ui && tsc -b && vite build",
    "preview": "npm run sync:swagger-ui && vite preview",
    "test": "vitest run src/**/*.test.ts src/**/*.test.tsx",
    "test:watch": "vitest src/**/*.test.ts src/**/*.test.tsx",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.6.0",
    "pmtiles": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "swagger-ui-dist": "^5.32.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.9"
